{
  "name": "@rline/orm",
  "version": "4.7.0",
  "author": {
    "name": "Robert Brightline",
    "email": "robert.brightline@gmail.com",
    "url": "https://rbrightline.github.io"
  },
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/swagger": "^8.1.0",
    "@nestjs/typeorm": "^10.0.2",
    "class-transformer": "^0.5.1",
    "typeorm": "^0.3.20"
  },
  "dependencies": {
    "@rline/property": "workspace:*",
    "@rline/type": "workspace:*",
    "@rline/utils": "workspace:^",
    "@rline/validation": "workspace:*",
    "@swc/helpers": "~0.5.11"
  },
  "type": "commonjs",
  "main": "./dist/index.js",
  "typings": "./dist/index.d.ts",
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "nx": {
    "sourceRoot": "libs/orm/src",
    "projectType": "library",
    "targets": {
      "build": {
        "executor": "@nx/js:swc",
        "outputs": [
          "{options.outputPath}"
        ],
        "options": {
          "outputPath": "libs/orm/dist",
          "main": "libs/orm/src/index.ts",
          "tsConfig": "libs/orm/tsconfig.lib.json",
          "skipTypeCheck": false,
          "stripLeadingPaths": true
        }
      },
      "test": {
        "executor": "@nx/vite:test",
        "outputs": [
          "{options.reportsDirectory}"
        ],
        "options": {
          "reportsDirectory": "../../coverage/libs/orm"
        }
      }
    },
    "name": "orm"
  },
  "devDependencies": {
    "better-sqlite3": "^11.7.0",
    "pg": "^8.13.1"
  }
}